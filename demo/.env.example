# bun run demo (src/run.ts): the full product walkthrough. It opens with two
# real sign-ins (your own site, then a third party), then runs the narrated,
# annotated product timeline and composes everything into ONE .mp4 per run.

DEMO_TARGET_URL=http://127.0.0.1:3999
DEMO_FIXTURE_PORT=0
DEMO_ENV_FILE=~/onspark/absolutejs/dealroom/.env
DEMO_OUTPUT_DIR=.demo-artifacts
DEMO_HEADLESS=false
DEMO_COMPOSE=true
# ElevenLabs key for the upgraded voiceover (loaded from DEMO_ENV_FILE by default).
ELEVENLABS_API_KEY=...

# Sign-in credentials — REQUIRED, no defaults. Passed to the profiles as env
# *references*, so values never enter the script, manifest, or recording.
# Own site (the fixture's login form). Any values work; the fixture accepts them.
OWN_SITE_EMAIL=owner@example.com
OWN_SITE_PASSWORD=demo-password
# Third party we don't control — saucedemo.com. These are its documented public
# test creds; swap for real creds + a real site.
SAUCE_USERNAME=standard_user
SAUCE_PASSWORD=secret_sauce

# --- bun run src/meet-scene.ts: AI talking inside a real meeting (Zoom) --------
# Zoom Server-to-Server OAuth app (marketplace.zoom.us → Develop → Build App →
# Server-to-Server OAuth; scope meeting:write; Activate). No waiting room, so the
# Recall bot joins + talks with no admission. (Recall/Deepgram load from dealroom.)
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
