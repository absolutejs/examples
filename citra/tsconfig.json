{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"noUncheckedIndexedAccess": true,
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"types": ["bun"]
	},
	"include": ["**/*.ts", "**/*.tsx"],
	"exclude": ["node_modules", "build", "indexes"]
}
