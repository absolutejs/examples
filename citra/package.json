{
	"name": "citra-example",
	"private": true,
	"type": "module",
	"version": "0.0.1",
	"description": "Runnable showcase for citra — authorize, callback, refresh, revoke, and fetch-profile against every supported OAuth2 provider.",
	"scripts": {
		"dev": "bun --watch --no-clear-screen server.ts",
		"start": "bun server.ts",
		"format": "absolute prettier --write",
		"lint": "absolute eslint",
		"typecheck": "absolute typecheck"
	},
	"dependencies": {
		"@absolutejs/absolute": "^0.19.0-beta.1038",
		"@elysiajs/static": "1.4.10",
		"citra": "^0.27.0",
		"elysia": "1.4.28",
		"react": "19.2.6",
		"react-dom": "19.2.6"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.0",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/bun": "1.3.14",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"@typescript-eslint/parser": "^8.59.3",
		"eslint": "^9",
		"eslint-plugin-absolute": "^0.11.2",
		"eslint-plugin-import-x": "^4.16.2",
		"eslint-plugin-jsx-a11y": "6.10.2",
		"eslint-plugin-promise": "7.3.0",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-react-compiler": "19.1.0-rc.2",
		"eslint-plugin-react-hooks": "7.1.1",
		"eslint-plugin-security": "4.0.0",
		"globals": "^17.6.0",
		"prettier": "3.8.3",
		"typescript": "5.9.3",
		"typescript-eslint": "8.59.3"
	}
}
