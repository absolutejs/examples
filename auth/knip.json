{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "drizzle": false,
  "entry": [
    "src/backend/server.ts",
    "absolute.config.ts",
    "drizzle.config.ts",
    "src/frontend/angular/pages/**/*.ts",
    "src/frontend/react/pages/**/*.tsx",
    "src/frontend/svelte/pages/**/*.svelte",
    "src/frontend/vue/pages/**/*.vue",
    "src/frontend/html/scripts/**/*.ts"
  ],
  "ignore": ["src/frontend/htmx/*.min.js"],
  "ignoreDependencies": ["react-refresh", "svelte-check", "vue-tsc"],
  "project": ["src/**/*.{ts,tsx,vue,svelte,js}"]
}
